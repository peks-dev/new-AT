---

<div class="lightbox-wrapper" role="dialog" aria-modal="true" aria-label="Vista de imagen">
  <button class="lightbox__close-btn" aria-label="Cerrar">
    <span class="lightbox__close-icon" aria-hidden="true"></span>
  </button>
  <button class="lightbox__nav-btn lightbox__nav-btn--prev" aria-label="Imagen anterior">
    <span aria-hidden="true">&#8592;</span>
  </button>
  <img src="" alt="" class="lightbox__img" />
  <button class="lightbox__nav-btn lightbox__nav-btn--next" aria-label="Imagen siguiente">
    <span aria-hidden="true">&#8594;</span>
  </button>
  <span class="lightbox__counter"></span>
</div>
<script src="./lightbox.js"></script>
<style>
  .lightbox-wrapper {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(0.8rem);
    -webkit-backdrop-filter: blur(0.8rem);
    z-index: 100;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .lightbox-wrapper.active {
    display: flex;
  }

  .lightbox__img {
    max-width: min(90vw, 90vh * 1.5);
    max-height: 85vh;
    width: auto;
    height: auto;
    object-fit: contain;
    position: relative;
    z-index: 5;
    border: 0.2rem solid rgba(215, 179, 156, 0.2);
  }

  .lightbox__close-btn {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 4.4rem;
    height: 4.4rem;
    background-color: transparent;
    border: var(--global-border-size) solid rgba(215, 179, 156, 0.4);
    border-radius: 50%;
    cursor: pointer;
    z-index: 10;
    display: grid;
    place-items: center;
    transition: background-color 0.2s ease, border-color 0.2s ease;
    color: var(--white);
  }

  .lightbox__close-btn:hover {
    background-color: rgba(215, 179, 156, 0.15);
    border-color: var(--global-border-color);
  }

  .lightbox__close-icon {
    position: relative;
    display: block;
    width: 1.6rem;
    height: 1.6rem;
  }

  .lightbox__close-icon::before,
  .lightbox__close-icon::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    height: 0.2rem;
    background-color: var(--global-border-color);
    border-radius: 2px;
  }

  .lightbox__close-icon::before {
    transform: rotate(45deg);
  }

  .lightbox__close-icon::after {
    transform: rotate(-45deg);
  }

  .lightbox__nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 4.8rem;
    height: 4.8rem;
    background-color: transparent;
    border: var(--global-border-size) solid rgba(215, 179, 156, 0.3);
    cursor: pointer;
    z-index: 10;
    display: grid;
    place-items: center;
    font-size: 2rem;
    color: var(--global-border-color);
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease;
  }

  .lightbox__nav-btn:hover {
    background-color: rgba(215, 179, 156, 0.12);
    border-color: var(--global-border-color);
    color: var(--white);
  }

  .lightbox__nav-btn--prev {
    left: 1.5rem;
  }

  .lightbox__nav-btn--next {
    right: 1.5rem;
  }

  .lightbox__counter {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-light);
    font-size: 1.4rem;
    color: rgba(215, 179, 156, 0.7);
    letter-spacing: 0.1rem;
    z-index: 10;
  }

  @media screen and (max-width: 600px) {
    .lightbox__nav-btn {
      width: 3.6rem;
      height: 3.6rem;
      font-size: 1.6rem;
    }

    .lightbox__nav-btn--prev {
      left: 0.8rem;
    }

    .lightbox__nav-btn--next {
      right: 0.8rem;
    }
  }
</style>
